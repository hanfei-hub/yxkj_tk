DATABASE_URL=mysql+pymysql://tk_user:CHANGE_ME@127.0.0.1:3306/tk_selection?charset=utf8mb4
PYTHONUNBUFFERED=1
TK_SELECTION_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTO_PUBLISH_IMAGE_WORKERS=8
AUTO_PUBLISH_BATCH_WORKERS=10
AUTO_PUBLISH_MEDIAKIT_CONCURRENCY=12
AUTO_PUBLISH_AI_IMAGE_TIMEOUT=75
AUTO_PUBLISH_DETAIL_IMAGE_SCAN_LIMIT=30
AUTO_PUBLISH_DETAIL_IMAGE_OUTPUT_LIMIT=15
MIAOSHOU_HEADLESS=1

# Public asset storage for local/intermediate images submitted to AI MediaKit.
# If backend and static files are served from the same domain, keep this path.
AUTO_PUBLISH_ASSET_BASE_URL=https://YOUR_DOMAIN_OR_IP/static/auto_publish

# Optional: estimated cost display. Update these if your contract price changes.
AUTO_PUBLISH_COST_AIMEDIAKIT_REMOVE_PER_1000=41.4
AUTO_PUBLISH_COST_AIMEDIAKIT_TRANSLATE_PER_1000=50
AUTO_PUBLISH_COST_ARK_PROMPT_PER_MILLION=2.4
AUTO_PUBLISH_COST_ARK_COMPLETION_PER_MILLION=3
